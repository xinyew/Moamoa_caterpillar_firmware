# Enable GPIO
CONFIG_GPIO=y

# Memory Execution (Run from RAM)
CONFIG_USE_DT_CODE_PARTITION=y
CONFIG_XIP=n

# Headless coprocessor: no UART on this board, no console at all.
# (Do NOT enable clock-control LFCLK options here - the app core's
# radio stack owns the CLOCK peripheral; the FLPR must not touch it.)
CONFIG_SERIAL=n
CONFIG_CONSOLE=n
