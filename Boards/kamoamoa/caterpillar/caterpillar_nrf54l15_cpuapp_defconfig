# Enable GPIO and MPU
CONFIG_GPIO=y
CONFIG_ARM_MPU=y

# Subsystem defaults for Caterpillar Hardware
CONFIG_I2C=y
CONFIG_PWM=y

# Disable UART, Enable Segger RTT for Debug
CONFIG_SERIAL=n
CONFIG_USE_SEGGER_RTT=y
CONFIG_RTT_CONSOLE=y

# no lfxo on this board
CONFIG_CLOCK_CONTROL_NRF_K32SRC_RC=y
CONFIG_CLOCK_CONTROL_NRF_K32SRC_XTAL=n

